NODE_ENV=development
HOST=127.0.0.1
PORT=3000

# Required. Change both values before running the server.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-password-of-at-least-12-characters
DATA_ENCRYPTION_KEY=replace-with-a-random-secret-of-at-least-32-characters
ADMIN_SESSION_HOURS=8
ADMIN_LOGIN_RATE_LIMIT=10
ADMIN_COOKIE_SECURE=false

# Gmail defaults. Override these values for another IMAP provider.
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_SECURE=true

# Set TRUST_PROXY=true only when the app is behind a trusted reverse proxy.
TRUST_PROXY=false
ADMIN_RATE_LIMIT=500
PUBLIC_RATE_LIMIT=30

# Optional path, relative to the project root or absolute.
NETFLIX_SESSION_FILE=data/netflix-session.json
ACCESS_KEYS_FILE=data/access-keys.json
