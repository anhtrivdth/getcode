APP_NAME=IMAP Code Resolver
ENVIRONMENT=dev
DATABASE_URL=sqlite:///./app.db

ADMIN_TOKEN=replace-with-strong-admin-token
ADMIN_PANEL_PASSWORD=123456
KEY_HASH_SECRET=replace-with-long-random-secret
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CREDENTIAL_ENCRYPT_KEY=

IMAP_SERVER=imap.gmail.com
IMAP_PORT=993
IMAP_FETCH_WINDOW_MINUTES=60
IMAP_MAX_MESSAGES_SCAN=30
RATE_LIMIT_MINUTES=180
CACHE_TTL_SECONDS=30
CODE_MAX_AGE_MINUTES=60
POLL_INTERVAL_SECONDS=90
